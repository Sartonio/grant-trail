{
  "name": "grant-trail-root",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "npm install --prefix frontend && cp frontend/.env.example frontend/.env.local && cp supabase/.env.example supabase/.env && npm run hooks:install",
    "prepare": "node scripts/install-git-hooks.js",
    "scope": "node scripts/scope.ts",
    "hooks:install": "node scripts/install-git-hooks.js",
    "db:check": "npx --prefix frontend supabase db diff",
    "db:start": "bash scripts/stack-lock.sh run npm run db:start --prefix frontend",
    "db:stop": "bash scripts/stack-lock.sh run npm run db:stop --prefix frontend",
    "db:reset": "bash scripts/stack-lock.sh run npm run db:reset --prefix frontend",
    "stack:who": "bash scripts/stack-lock.sh who",
    "dev": "bash scripts/dev.sh",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:functions": "npx --prefix frontend supabase functions serve --env-file ./supabase/functions/.env",
    "build": "npm run build --prefix frontend",
    "test": "npm run test --prefix frontend",
    "verify": "npm run verify --prefix frontend",
    "verify:full": "bash scripts/verify-full.sh",
    "verify:changed": "bash scripts/verify-changed.sh",
    "verify:rls": "bash scripts/verify-lib.sh sql",
    "verify:edge": "bash scripts/verify-lib.sh edge_identity stripe_matrix",
    "verify:edge:static": "bash scripts/verify-lib.sh edge_static",
    "verify:e2e": "bash scripts/verify-lib.sh e2e",
    "e2e": "bash scripts/e2e.sh",
    "e2e:install": "npm run e2e:install --prefix frontend",
    "deploy:secrets": "node scripts/deploy_secrets.js --env production",
    "deploy:secrets:staging": "node scripts/deploy_secrets.js --env staging",
    "deploy:secrets:ci": "node scripts/deploy_secrets.js --env ci",
    "functions:prune": "node scripts/prune_functions.js",
    "admin:promote": "node scripts/promote_admin.js"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
