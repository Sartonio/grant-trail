{
  "name": "grant-trail-root",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "npm install --prefix frontend && cp frontend/.env.example frontend/.env.local && cp supabase/.env.example supabase/.env && npm run hooks:install",
    "prepare": "node scripts/install-git-hooks.js",
    "hooks:install": "node scripts/install-git-hooks.js",
    "db:check": "npx --prefix frontend supabase db diff",
    "db:start": "npm run db:start --prefix frontend",
    "db:stop": "npm run db:stop --prefix frontend",
    "db:reset": "npm run db:reset --prefix frontend",
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "test": "npm run test --prefix frontend",
    "e2e": "npm run e2e --prefix frontend",
    "e2e:install": "npm run e2e:install --prefix frontend",
    "deploy:secrets": "node scripts/deploy_secrets.js --env production",
    "deploy:secrets:staging": "node scripts/deploy_secrets.js --env staging",
    "deploy:secrets:ci": "node scripts/deploy_secrets.js --env ci",
    "functions:prune": "node scripts/prune_functions.js",
    "admin:promote": "node scripts/promote_admin.js"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
