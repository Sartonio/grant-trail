# Fill MANDATORY + OPTIONAL; leave AUTOFILLED blank. Guide: docs/how_to/prod_setup.md

# === MANDATORY ===

# Supabase
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_DIRECTORY=

# Vercel
VERCEL_TOKEN=

# Email (Resend HTTP API — see EMAIL-DNS-SETUP.md / docs/PROD-EMAIL-RUNBOOK.md)
RESEND_API_KEY=     # Resend API key (re_...)

# App
APP_URL=https://staging-grant-trail.vercel.app

# === OPTIONAL ===

# Stripe
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# Email
# Use a Resend-verified domain — onboarding@resend.dev only delivers to the Resend
# account owner. Verify the domain (EMAIL-DNS-SETUP.md), then set e.g.
# EMAIL_FROM="GrantTrail <receipts@send.atkasolutions.org>".
EMAIL_FROM=

# Observability
VITE_SENTRY_DSN=

# === AUTOFILLED ===

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# Stripe
STRIPE_WEBHOOK_SECRET=

# Vercel
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
