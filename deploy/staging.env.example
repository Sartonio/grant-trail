# ─────────────────────────────────────────────────────────────────────────────
# STAGING config — feeds the GitHub `staging` Environment.
#
# Copy this to `.deploy/staging.env` (git-ignored), fill in the values, then:
#
#     npm run deploy:secrets:staging
#
# That pushes every key below into the GitHub `staging` environment. The staging
# deploy workflow is the ONLY consumer — it sets Supabase secrets, injects the
# Vite build vars, and deploys. You never touch the Supabase / Vercel / GitHub
# dashboards by hand.
#
# Same key names as production, just different (staging-project) values. Re-run
# the command any time you change a value. It's idempotent.
#
# You only fill in by hand: the 3 account tokens (Supabase / Stripe / Vercel),
# SUPABASE_PROJECT_REF, APP_URL, and the two STRIPE_PRICE_* ids. Keys marked
# "AUTO" are fetched for you on run — leave them blank. The file is deleted after
# a successful push (run with --keep to retain it).
# ─────────────────────────────────────────────────────────────────────────────

# === SECRETS (stored as GitHub Actions *secrets* — masked in logs) ===========

# Supabase personal access token — https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Stripe secret key for the staging Stripe account/mode — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# AUTO — leave blank. On run, the script creates the webhook endpoint via the
# Stripe CLI (using STRIPE_SECRET_KEY) and captures its signing secret. If an
# endpoint already exists, Stripe won't re-reveal the secret: either paste it
# here, or re-run with --recreate-webhook to rotate it.
STRIPE_WEBHOOK_SECRET=

# Vercel access token — https://vercel.com/account/settings/tokens
VERCEL_TOKEN=
# AUTO — leave blank. Read from .vercel/project.json after you run `npx vercel link`.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Optional — Resend API key for payment confirmation emails (re_...).
# https://resend.com/api-keys  · leave blank to disable email sending.
RESEND_API_KEY=

# === VARIABLES (stored as GitHub Actions *variables* — plain text) ===========

# Supabase staging project ref (the short id in the project URL).
SUPABASE_PROJECT_REF=

# Stripe price IDs. List them with:  stripe prices list --limit 100
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# Optional — Stripe billing portal configuration id (bpc_...). Leave blank to use
# the Stripe account default. List with: stripe billing_portal configurations list
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# Public app URL — where Stripe redirects users after checkout/portal.
APP_URL=https://staging-grant-trail.vercel.app

# Vite build vars (public — they ship in the browser bundle).
# AUTO — leave blank. Derived from SUPABASE_PROJECT_REF.
VITE_SUPABASE_URL=
# AUTO — leave blank. Fetched via the Supabase CLI using SUPABASE_ACCESS_TOKEN
# (the sb_publishable_... key). Paste it manually if the fetch can't run.
VITE_SUPABASE_KEY=

# Optional — Sentry DSN for staging error reporting. Leave blank to disable.
VITE_SENTRY_DSN=

# Optional — "From" address on outgoing emails. Must be a Resend-verified domain.
# Defaults to "GrantTrail <noreply@granttrail.ca>" if left blank.
RESEND_FROM_EMAIL=
