# ─────────────────────────────────────────────────────────────────────────────
# Production config — THE single source of truth.
#
# Copy this to `.deploy/prod.env` (git-ignored), fill in the values, then run:
#
#     npm run deploy:secrets
#
# That pushes every key below into the GitHub `production` environment. The
# "Deploy to Production" workflow (.github/workflows/deploy-prod.yml) is the only
# thing that reads them — it sets Supabase secrets, injects the Vite build vars,
# and deploys. You never touch the Supabase / Vercel / GitHub dashboards by hand.
#
# Re-run the command any time you change a value. It's idempotent.
# ─────────────────────────────────────────────────────────────────────────────

# === SECRETS (stored as GitHub Actions *secrets* — masked in logs) ===========

# Supabase personal access token — https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Stripe live secret key — https://dashboard.stripe.com/apikeys  (sk_live_...)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...) for the prod endpoint.
# Create the endpoint + grab the secret in one shot with the Stripe CLI:
#   stripe webhook_endpoints create \
#     --url https://<prod-ref>.supabase.co/functions/v1/stripe-webhook \
#     --enabled-events checkout.session.completed \
#     --enabled-events customer.subscription.updated \
#     --enabled-events customer.subscription.deleted
# The response's "secret" field is the value below.
STRIPE_WEBHOOK_SECRET=

# Vercel access token — https://vercel.com/account/settings/tokens
VERCEL_TOKEN=
# Vercel org + project IDs. After `npx vercel link`, both are in .vercel/project.json
# (orgId / projectId), or run `npx vercel project ls`.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# === VARIABLES (stored as GitHub Actions *variables* — plain text) ===========

# Supabase prod project ref (the short id in the project URL).
SUPABASE_PROD_PROJECT_REF=

# Stripe price IDs. List them with:  stripe prices list --limit 100
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# Optional — Stripe billing portal configuration id (bpc_...). Leave blank to use
# the Stripe account default. List with: stripe billing_portal configurations list
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# Public app URL — where Stripe redirects users after checkout/portal.
APP_URL=https://grant-trail.vercel.app

# Vite build vars (public — they ship in the browser bundle).
# Leave VITE_SUPABASE_URL blank to auto-derive it from SUPABASE_PROD_PROJECT_REF.
VITE_SUPABASE_URL=
# Supabase publishable key (sb_publishable_...) from Project Settings → API.
VITE_SUPABASE_KEY=

# Optional — Sentry DSN for prod error reporting. Leave blank to disable.
VITE_SENTRY_DSN=
