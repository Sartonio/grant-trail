# PRODUCTION → GitHub `production` environment.  Fill the block below, then:
#     npm run deploy:secrets
# Git-ignored; self-deletes after a successful push (use --keep to retain).

# ── FILL THESE ───────────────────────────────────────────────────────────────
# Run once first:  npx vercel link   (links the repo so VERCEL_ORG_ID/PROJECT_ID auto-fill)
SUPABASE_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET: leave blank to auto-create the endpoint; if one already
# exists, paste its signing secret (Stripe won't re-reveal it).
STRIPE_WEBHOOK_SECRET=
VERCEL_TOKEN=
SUPABASE_PROJECT_REF=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
APP_URL=https://grant-trail.vercel.app

# ── AUTO — leave blank ───────────────────────────────────────────────────────
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
VITE_SENTRY_DSN=
