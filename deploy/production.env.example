# === MANDATORY ===

# Supabase
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
# DB connection password (dashboard → Project Settings → Database). Lets the
# CLI connect directly for `db push`/`db query` instead of provisioning a
# temporary login role (which needs privileges our identity lacks).
SUPABASE_DB_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRODUCT_BASIC=
STRIPE_PRICE_BASIC=
STRIPE_PRODUCT_FISCAL_AGENT=
STRIPE_PRICE_FISCAL_AGENT=
STRIPE_WEBHOOK_SECRET=        

# Vercel
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Email
RESEND_API_KEY=
EMAIL_FROM=GrantTrail <notifications@send.atkasolutions.org>

# App
APP_URL=



# === OPTIONAL ===

# Stripe
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# Extra origins Stripe may redirect back to after checkout/portal, beyond APP_URL.
# Comma-separated; exact origins or `https://*.<account-scoped-suffix>` wildcards
# (never a shared host like `vercel.app`). Unknown origins fall back to APP_URL.
# Set this to let Vercel preview deployments return to their own URL.
APP_URL_ALLOWED_ORIGINS=

# Observability
VITE_SENTRY_DSN=
# Source-map upload — makes production stack traces readable instead of minified.
# SENTRY_AUTH_TOKEN is a secret; create one at
# https://<org>.sentry.io/settings/auth-tokens/ with `project:releases` + `org:read`.
# Leave the token blank to skip the upload (the build still succeeds).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === AUTOFILLED ===

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
