# ─────────────────────────────────────────────────────────────────────────────
# CI config — feeds the GitHub `ci` Environment.
#
# Copy this to `.deploy/ci.env` (git-ignored), fill in the values, then:
#
#     npm run deploy:secrets:ci
#
# That pushes the three Stripe *test* secrets below into the GitHub `ci`
# environment. The CI workflow is the ONLY consumer — it runs the test suite
# against Stripe test mode. You never set these in the GitHub dashboard by hand.
#
# Test-mode only — no live keys, no auto-fetch. Re-run any time you change a
# value. It's idempotent. The file is deleted after a successful push (run with
# --keep to retain it).
# ─────────────────────────────────────────────────────────────────────────────

# === SECRETS (stored as GitHub Actions *secrets* — masked in logs) ===========

# Stripe TEST secret key — https://dashboard.stripe.com/test/apikeys  (sk_test_...)
STRIPE_SECRET_KEY_TEST=

# Stripe TEST price IDs. List them with:
#   stripe prices list --limit 100 --api-key sk_test_...
STRIPE_PRICE_BASIC_TEST=
STRIPE_PRICE_PRO_TEST=
