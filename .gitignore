*.zip
*:Zone.Identifier
.vscode/
.env.local
.deploy/
bin/
.claude/*
# Track project subagent definitions (shared with cloud/other clones); keep the rest of .claude local
!.claude/agents/
.vercel
.env*
# Incidental local-tooling artifacts (repo app deps live under frontend/)
/node_modules/
/deno.lock

# Keep env templates tracked despite .env* above (e.g. supabase/functions/.env.example)
!.env.example

# Playwright (frontend e2e artifacts; can land at repo root or frontend/ depending on cwd)
/playwright-report/
/test-results/
/frontend/playwright-report/
/frontend/test-results/
/test-results/
