#!/usr/bin/env sh
#
# pre-push: block pushes that contain local database schema changes which have
# NOT been captured in a migration file.
#
# How it works: `supabase db diff` rebuilds the schema from supabase/migrations/
# in a shadow database and compares it against your running local dev database.
# Recent CLI versions print a one-line JSON envelope to stdout whose `diff`
# field holds the missing DDL ("\n" when the schemas match); older versions
# printed the raw DDL (or nothing). We extract the DDL from the envelope when
# present and fall back to raw stdout otherwise. DO_NOT_TRACK=1 is required:
# without it the CLI's telemetry flush times out and forces exit code 1 even
# on success, which would send every run down the fail-open path below.
#
# Graceful by design: if the check cannot run (Docker not running, local DB not
# started), it warns and lets the push through — CI rebuilds the DB from
# migrations as a backstop. Bypass explicitly with `SKIP_DB_DIFF=1 git push`
# or `git push --no-verify`.

set -u

if [ "${SKIP_DB_DIFF:-}" = "1" ]; then
  echo "pre-push: SKIP_DB_DIFF=1 — skipping schema-drift check."
  exit 0
fi

ROOT=$(git rev-parse --show-toplevel) || exit 0
cd "$ROOT" || exit 0

echo "pre-push: checking for local schema changes not captured in a migration..."

errfile=$(mktemp 2>/dev/null || echo "/tmp/granttrail_dbdiff.$$")
diff_out=$(DO_NOT_TRACK=1 npx --prefix frontend supabase db diff 2>"$errfile")
status=$?

if [ "$status" -ne 0 ]; then
  echo "⚠️  pre-push: could not run 'supabase db diff'."
  echo "    Is Docker running and the local DB started ('npm run db:start')?"
  echo "    Skipping the schema-drift check — CI still rebuilds the DB from migrations."
  if [ -s "$errfile" ]; then
    echo "    Details:"
    sed 's/^/      /' "$errfile"
  fi
  rm -f "$errfile"
  exit 0
fi
rm -f "$errfile"

# Pull the DDL out of the JSON envelope (first line with a string `diff`
# field); if no line parses as such, treat stdout as raw DDL (older CLIs).
ddl=$(printf '%s' "$diff_out" | node -e '
  let s = "";
  process.stdin.on("data", (d) => (s += d)).on("end", () => {
    let out = s;
    for (const line of s.split("\n")) {
      if (!line.trim()) continue;
      try {
        const j = JSON.parse(line);
        if (j && typeof j.diff === "string") { out = j.diff; break; }
      } catch (_) { /* not JSON — keep raw fallback */ }
    }
    process.stdout.write(out);
  });
')

# Whitespace-only DDL == no uncaptured changes.
if [ -n "$(printf '%s' "$ddl" | tr -d '[:space:]')" ]; then
  echo ""
  echo "❌ pre-push blocked: your local database has schema changes that are NOT in a migration file:"
  echo ""
  printf '%s\n' "$ddl" | sed 's/^/    /'
  echo ""
  echo "Capture them into a migration before pushing:"
  echo "    npx --prefix frontend supabase db diff -f <descriptive_name>"
  echo "    git add supabase/migrations/ && git commit"
  echo ""
  echo "See docs/how_to/dev_practices.md. To bypass (not recommended): git push --no-verify"
  exit 1
fi

echo "✓ pre-push: no uncaptured schema changes."

# --- Definition-of-Done fast tier ------------------------------------------
# Run `npm run verify` (lint + typecheck + unit tests) before letting a push
# through. Bypass with SKIP_VERIFY=1 git push (or git push --no-verify).
# The stack tier (verify:full) is intentionally NOT run here — it needs Docker
# + Stripe keys and would make every push slow/flaky; the schema-drift check
# above already keeps DB changes honest, and CI runs the full tier.
if [ "${SKIP_VERIFY:-}" = "1" ]; then
  echo "pre-push: SKIP_VERIFY=1 — skipping npm run verify."
  exit 0
fi

echo "pre-push: running 'npm run verify' (lint + typecheck + unit tests)..."
if ! npm run verify >/dev/null 2>&1; then
  echo ""
  echo "❌ pre-push blocked: 'npm run verify' failed."
  echo "   Run it to see the failures:  npm run verify"
  echo "   To bypass (not recommended): SKIP_VERIFY=1 git push   (or git push --no-verify)"
  exit 1
fi

echo "✓ pre-push: npm run verify passed."
exit 0
