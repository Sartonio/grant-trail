# Stripe API secrets for local Edge Functions testing
# Copy this file to .env inside the supabase/ folder.
# supabase/.env is git-ignored.

# Stripe secret API key (sk_test_...)
STRIPE_SECRET_KEY=""

# Stripe price IDs matching your Stripe product setup
STRIPE_PRICE_BASIC="price_1QxBasicTestId"
STRIPE_PRICE_PRO="price_1QxPremiumTestId"

# Stripe webhook signing secret (whsec_...)
# Local: from `stripe listen`. Production: from the webhook endpoint you create
# in the Stripe Dashboard. Leave blank until you have it.
STRIPE_WEBHOOK_SECRET=""

# App frontend URL — http://localhost:3000 for local, your Vercel URL for production
APP_URL="http://localhost:3000"

# Resend API key for transactional emails (payment confirmations, receipts)
# Get yours at https://resend.com — leave blank to disable email sending locally
RESEND_API_KEY=""

# The "From" address shown on outgoing emails. Must be a verified domain in Resend.
# Default: GrantTrail <noreply@granttrail.ca>
RESEND_FROM_EMAIL=""
