# Template for local Supabase Edge Function secrets. Copy to `.env` and fill in.
#   cp supabase/functions/.env.example supabase/functions/.env
#
# Generate working test-mode values with the Stripe CLI (no account required):
#   stripe sandbox create --email you@example.com   # -> STRIPE_SECRET_KEY
#   stripe listen --print-secret                    # -> STRIPE_WEBHOOK_SECRET
# Create recurring prices, then paste their IDs below:
#   stripe products create --name "Basic"
#   stripe prices create --product prod_xxx --unit-amount 900 --currency usd -d "recurring[interval]=month"
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by `supabase functions serve` — do not set them here.

# --- Stripe (use TEST-mode keys only for local dev) ---
STRIPE_SECRET_KEY=rk_test_or_sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_FISCAL_AGENT_ACCESS=price_xxx
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_xxx

APP_URL=http://localhost:3000
