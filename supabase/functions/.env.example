# Local Edge Function secrets — copy to supabase/functions/.env.
# SUPABASE_* are injected by `supabase functions serve` — don't set them here.
# Guide: docs/how_to/local_stripe_testing.md

# === MANDATORY ===

# Stripe (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_FISCAL_AGENT=

# App
APP_URL=http://localhost:3000

# === OPTIONAL ===

# Stripe
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# Extra origins Stripe may redirect back to after checkout/portal, beyond APP_URL.
# Comma-separated. Each entry is either an exact origin or a wildcard
# `https://*.<suffix>` where <suffix> is an ACCOUNT-SCOPED domain nobody else can
# register subdomains under (safe: your Vercel account preview domain; UNSAFE:
# `vercel.app`). Unknown origins silently fall back to APP_URL. Leave empty to
# keep today's behaviour (all checkouts return to APP_URL).
# `*` matches DNS-label chars (no dots). Vercel preview URLs are one hyphen-joined
# label, so the scope goes after a hyphen:
# e.g. APP_URL_ALLOWED_ORIGINS=https://*-programmer484s-projects.vercel.app
APP_URL_ALLOWED_ORIGINS=

# Email (Resend HTTP API). Both required to send; unset = email is skipped.
# EMAIL_FROM must be on a domain verified in your Resend account.
RESEND_API_KEY=
EMAIL_FROM=
