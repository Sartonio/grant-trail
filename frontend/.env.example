# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.
#
# Find these values in:
# Supabase Dashboard → Project Settings → API

# Your Supabase project URL
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Your Supabase anon/public key (safe to expose in the browser)
VITE_SUPABASE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Sentry DSN for frontend crash and unhandled rejection tracking (optional in dev)
VITE_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# Source-map upload (production/CI builds only). These are read from the build
# environment (process.env), NOT bundled into the client. Set them as CI/hosting
# secrets — e.g. Vercel project env vars — or export them in your shell to test a
# source-map upload locally. If SENTRY_AUTH_TOKEN is unset, the upload is skipped.
#   SENTRY_ORG=your-org-slug
#   SENTRY_PROJECT=granttrail-frontend
#   SENTRY_AUTH_TOKEN=  # secret — never commit

# Optional Stripe product ID overrides. Normally the product IDs are synced into
# platform_settings from the STRIPE_PRICE_* env vars by the Edge Functions, and the
# frontend reads them from there. Set these only if you want to pin the IDs at build
# time as a fallback. Leave blank otherwise — no product ID is hard-coded.
VITE_STRIPE_PRODUCT_BASIC=
VITE_STRIPE_PRODUCT_PREMIUM=
