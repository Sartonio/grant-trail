{
  "name": "tfac-dashboard",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@sentry/react": "^10.58.0",
    "@supabase/supabase-js": "^2.84.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "exceljs": "^4.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "npm-run-all2": "^8.0.4",
    "supabase": "^2.109.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "prebuild": "node scripts/check-env.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "verify": "run-p --print-label lint typecheck typecheck:strict test",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ src",
    "deadcode": "knip",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset && npm run db:types",
    "db:types": "sh -c 'tmp=$(mktemp) && DO_NOT_TRACK=1 supabase gen types typescript --local > \"$tmp\" || { echo \"db:types: supabase gen types failed\" >&2; rm -f \"$tmp\"; exit 1; }; if grep -q \\\"_tag\\\":\\\"Error\\\" \"$tmp\"; then echo \"db:types: generated output contains errors\" >&2; rm -f \"$tmp\"; exit 1; fi; mv \"$tmp\" src/lib/database.types.ts'"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
