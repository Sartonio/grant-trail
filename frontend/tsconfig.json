{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "types": ["vite/client"]
  },
  "//": "Enforced scope: the whole of src, type-clean as of 2026-06-30. Includes",
  "// ": "src/types/*.d.ts (the react-icons className/style augmentation — must stay",
  "//  ": "in the program for the augmentation to take effect). Any new file must be",
  "//   ": "added type-clean; don't widen `any`/ts-ignore your way past a real error.",
  "include": ["src/**/*.js", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "tests", "**/*.test.js"]
}
