{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "types": ["vite/client"]
  },
  "//": "Enforced scope: the load-bearing access-control/data/hooks closure, plus",
  "// ": "src/utils (pure, fully-typed) and a handful of clean leaf components. The",
  "//  ": "rest of src is excluded until annotated — ratchet the include list outward",
  "//   ": "as files are cleaned up. TODO(types): widen.",
  "include": [
    "src/lib/**/*.js",
    "src/hooks/**/*.js",
    "src/utils/**/*.js",
    "src/supabaseClient.js",
    "src/components/common/StatusBadge.js",
    "src/components/common/ReadOnlyBanner.js",
    "src/components/layout/Footer.js",
    "src/components/layout/NotificationBell.js"
  ],
  "exclude": ["node_modules", "dist", "tests", "**/*.test.js"]
}
