{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "types": ["vite/client"]
  },
  "//": "Enforced scope: the load-bearing access-control/data/hooks closure. The",
  "// ": "rest of src (components, legacy utils, *.test.js) is excluded until annotated",
  "//  ": "— ratchet the include list outward as files are cleaned up. TODO(types): widen.",
  "include": [
    "src/lib/**/*.js",
    "src/hooks/**/*.js",
    "src/supabaseClient.js"
  ],
  "exclude": ["node_modules", "dist", "tests", "**/*.test.js"]
}
